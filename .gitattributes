# Normalise line endings to LF in the repository on all platforms.
* text=auto eol=lf

# Dart / Flutter source
*.dart text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.xml  text eol=lf
*.kts  text eol=lf
*.kt   text eol=lf
*.gradle text eol=lf
*.properties text eol=lf

# Binary — never diff or convert
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.docx binary
*.apk  binary
*.aab  binary
*.keystore binary
